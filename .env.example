# AWS Credentials (Required if not already configured via 'aws configure')
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# (Optional) Required only if you are using temporary session credentials
# AWS_SESSION_TOKEN=your_session_token_here

# Bedrock Region (Defaults to ap-south-1 if not set)
BEDROCK_REGION=ap-south-1
